<% if (theme.comment.enable && theme.comment.type === 'gitalk') { %>
    <div id="gitalk-container"></div>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gitalk@1.7.2/dist/gitalk.css">
    <script src="https://cdn.jsdelivr.net/npm/gitalk@1.7.2/dist/gitalk.min.js"></script>
    <script>

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
            gitalk.render('gitalk-container');
            observer.unobserve(entry.target);
            }
        });
        });
    observer.observe(document.getElementById('gitalk-container'));

      const gitalk = new Gitalk({
        clientID: '<%= theme.comment.gitalk_client_id %>',
        clientSecret: '<%= theme.comment.gitalk_client_secret %>',
        repo: '<%= theme.comment.gitalk_repo %>',      // 存放评论的仓库
        owner: '<%= theme.comment.gitalk_owner %>',    // GitHub 用户名
        admin: ['<%= theme.comment.gitalk_admin %>'],  // 管理员账号
        id: location.pathname,                         // 唯一标识符
        distractionFreeMode: false
      })
      gitalk.render('gitalk-container')
    </script>
    <% } %>